{
  "info": {
    "name": "AiAssistant Agentic API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",     "value": "http://localhost:5222" },
    { "key": "keycloak_url", "value": "http://localhost:8190" },
    { "key": "client_id",    "value": "ai-assistant-api-test" },
    { "key": "token",        "value": "" },
    { "key": "password",     "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token – HR (mikloscsaba)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "{{client_id}}" },
                { "key": "username",   "value": "mikloscsaba" },
                { "key": "password",   "value": "{{password}}" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/ai-assistant/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "ai-assistant", "protocol", "openid-connect", "token"]
            }
          }
        },
        {
          "name": "Get Token – CEO (johndoe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "{{client_id}}" },
                { "key": "username",   "value": "johndoe" },
                { "key": "password",   "value": "{{password}}" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/ai-assistant/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "ai-assistant", "protocol", "openid-connect", "token"]
            }
          }
        },
        {
          "name": "Get Token – User (butorgergo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id",  "value": "{{client_id}}" },
                { "key": "username",   "value": "butorgergo" },
                { "key": "password",   "value": "{{password}}" }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/ai-assistant/protocol/openid-connect/token",
              "host": ["{{keycloak_url}}"],
              "path": ["realms", "ai-assistant", "protocol", "openid-connect", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Agent",
      "item": [
        {
          "name": "Ask – szerződés + DB kombináció",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Mi Szabó Márton fizetése és hány nap szabadsága van?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        },
        {
          "name": "Ask – szerződés kérdés (CONTRACT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Mi Kovács Márton pozíciója és mennyi a bruttó fizetése?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        },
        {
          "name": "Ask – HR szabályzat kérdés",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Mennyi a felmondási idő?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        },
        {
          "name": "Ask – adatbázis kérdés",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Kik dolgoznak az Engineering részlegen?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        },
        {
          "name": "Ask – szabadság kérelem státusz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Milyen jóváhagyott szabadságkérelmei vannak Szabó Mártonnak?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth check",
      "item": [
        {
          "name": "Ask token nélkül – 401",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"test\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/agent/ask",
              "host": ["{{base_url}}"],
              "path": ["api", "agent", "ask"]
            }
          }
        }
      ]
    }
  ]
}
